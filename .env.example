# ===========================================
# pulse - Environment Configuration
# ===========================================
# Copy this file to .env and fill in actual values

# --- Plane.so ---
PULSE_PLANE_API_KEY=your_plane_api_key_here
PULSE_PLANE_BASE_URL=https://plane.example.com
PULSE_PLANE_WORKSPACE_SLUG=your_workspace_slug

# Plane.so Project ID (generated by scripts/setup.sh)
PULSE_DAILY_QUEST_PROJECT_ID=

# Plane.so State UUIDs (generated by scripts/setup.sh)
PULSE_STATE_TODO_ID=
PULSE_STATE_IN_PROGRESS_ID=
PULSE_STATE_DEFERRED_ID=
PULSE_STATE_DONE_ID=
PULSE_STATE_CANCELED_ID=

# Plane.so Label UUID (generated by scripts/setup.sh)
PULSE_LABEL_DAILY_ROUTINE_ID=

# --- DeepSeek ---
PULSE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
PULSE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
PULSE_DEEPSEEK_MODEL=deepseek-chat

# --- LobeHub ---
PULSE_LOBEHUB_WEBHOOK_URL=https://lobehub.example.com/webhook
PULSE_LOBEHUB_API_KEY=your_lobehub_api_key_here

# --- n8n ---
PULSE_N8N_WEBHOOK_SECRET=your_webhook_secret_here

# --- General ---
PULSE_USER_TIMEZONE=Asia/Seoul
PULSE_DRY_RUN=false

# --- NL Classification (Epic 6) ---
PULSE_CLASSIFY_CONFIDENCE_THRESHOLD=high
PULSE_CLASSIFY_TIMEOUT_MS=15000
